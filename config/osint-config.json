{
  "project": {
    "name": "nknc-onto-osint",
    "topic": "North Korea Nuclear Activity Monitoring",
    "description": "북한의 핵무기 개발, 핵실험, 미사일 발사, 핵시설 활동, 국제 제재 및 비핵화 협상 등 핵 관련 동향을 추적하는 OSINT 시스템",
    "goals": [
      "북한 핵/미사일 활동 동향 모니터링",
      "핵시설 및 관련 인프라 변화 감지",
      "핵심 인물 및 조직 관계 추적",
      "국제 제재 및 비핵화 협상 진행 상황 추적",
      "위성 영상 분석 보고서 및 전문가 평가 수집"
    ],
    "scope": {
      "include": [
        "북한 핵실험", "핵무기 개발", "우라늄 농축", "플루토늄 재처리",
        "ICBM", "SLBM", "탄도미사일", "핵탄두",
        "영변 핵시설", "풍계리 핵실험장", "동창리 발사장", "서해위성발사장",
        "비핵화 협상", "6자회담", "CVID", "핵동결",
        "UN 안보리 대북제재", "IAEA 사찰",
        "핵확산", "핵물질 이전", "핵기술 수출"
      ],
      "exclude": [
        "북한 일반 내정", "탈북자 개인사", "한류 문화",
        "남북 스포츠 교류", "일반 관광"
      ]
    },
    "report_language": "ko",
    "lookback_days": 7,
    "schedule_cron": "0 23 * * *",
    "schedule_description": "KST 08:00 매일"
  },

    "reasoning_rules": [
      {
        "id": "transitivity",
        "description": "A가 B에 소속되고 B가 C에 소속되면 A는 C에도 간접 소속",
        "pattern": "(?x affiliatedWith ?y) AND (?y affiliatedWith ?z) => (?x indirectlyAffiliatedWith ?z)"
      },
      {
        "id": "event_chain",
        "description": "사건 A가 사건 B를 유발하고 B가 C를 유발하면 A-C 인과 체인",
        "pattern": "(?a causedBy ?b) AND (?b causedBy ?c) => (?a causalChain ?c)"
      },
      {
        "id": "co_participation",
        "description": "같은 사건에 참여한 엔티티는 잠재적 관계",
        "pattern": "(?x participatesIn ?e) AND (?y participatesIn ?e) => (?x potentialRelation ?y)"
      },
      {
        "id": "sanction_escalation",
        "description": "핵실험/미사일 발사 후 제재 조치가 뒤따르면 escalation 패턴",
        "pattern": "(?test type NuclearTest|MissileLaunch) AND (?sanction type SanctionAction) AND (?sanction follows ?test) => (?test triggeredEscalation ?sanction)"
      },
      {
        "id": "facility_weapon_link",
        "description": "시설에서 개발된 무기가 발사에 사용되면 시설-발사 연결",
        "pattern": "(?ws developsAt ?fac) AND (?launch usesWeaponSystem ?ws) => (?fac linkedToLaunch ?launch)"
      },
      {
        "id": "proliferation_network",
        "description": "엔티티 A가 B에 공급하고 B가 C에 공급하면 확산 네트워크",
        "pattern": "(?a suppliesTo ?b) AND (?b suppliesTo ?c) => (?a proliferationNetwork ?c)"
      }
    ],
    "max_new_classes_per_day": 5,
    "max_new_relations_per_day": 10,
    "confidence_threshold": 0.7
  },
  "report": {
    "format": "markdown",
    "include_kg_visualization": true,
    "kg_visualization_format": "mermaid",
    "max_kg_nodes": 30,
    "wiki_publish": true,
    "empty_report_message": "금일 북한 핵활동 관련 특이사항 없음"
  }

      { "id": "locatedIn", "label": "위치", "domain": "Entity", "range": "Location" },
      { "id": "relatedTo", "label": "관련", "domain": "Entity", "range": "Entity" },
      { "id": "causedBy", "label": "원인", "domain": "Event", "range": "Event" },
      { "id": "follows", "label": "후속", "domain": "Event", "range": "Event" },
      { "id": "mentions", "label": "언급", "domain": "Entity", "range": "Concept" },
      { "id": "opposes", "label": "대립", "domain": "Entity", "range": "Entity" },
      { "id": "cooperatesWith", "label": "협력", "domain": "Entity", "range": "Entity" },
      { "id": "commands", "label": "지휘", "domain": "Person", "range": "Organization" },
      { "id": "developsAt", "label": "개발장소", "domain": "WeaponSystem", "range": "NuclearFacility" },
      { "id": "testedAt", "label": "실험장소", "domain": "NuclearTest", "range": "TestSite" },
      { "id": "launchedFrom", "label": "발사장소", "domain": "MissileLaunch", "range": "LaunchSite" },
      { "id": "sanctionedBy", "label": "제재주체", "domain": "Entity", "range": "SanctionAction" },
      { "id": "targets", "label": "제재대상", "domain": "SanctionAction", "range": "Entity" },
      { "id": "violates", "label": "위반", "domain": "Event", "range": "Treaty" },
      { "id": "usesWeaponSystem", "label": "사용무기", "domain": "MissileLaunch", "range": "WeaponSystem" },
      { "id": "producesMaterial", "label": "생산물질", "domain": "NuclearFacility", "range": "NuclearMaterial" },
      { "id": "suppliesTo", "label": "공급", "domain": "Entity", "range": "Entity" },
      { "id": "monitorsBy", "label": "감시주체", "domain": "NuclearFacility", "range": "InternationalOrg" }
